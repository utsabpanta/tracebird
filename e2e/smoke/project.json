{
  "name": "smoke",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "e2e/smoke/src",
  "projectType": "application",
  "tags": ["scope:e2e"],
  "targets": {
    "e2e": {
      "executor": "nx:run-commands",
      "dependsOn": [{ "projects": ["cli"], "target": "build" }],
      "options": {
        "command": "vitest run",
        "cwd": "e2e/smoke"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint src",
        "cwd": "e2e/smoke"
      }
    }
  }
}
